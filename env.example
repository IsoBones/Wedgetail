# ===== Required =====

# Discord Bot Token (from Discord Developer Portal)
TOKEN=your_bot_token_here

# Channel ID where advertisements are posted
AD_CHANNEL_ID=your_ad_channel_id_here

# ===== Optional =====

# Embed colour (6-digit hex). Defaults to Wedgetail teal #14B8A6 if unset.
EMBED_COLOR=#14B8A6

# Discord Client ID (Bot Application ID) - reserved for future use
CLIENT_ID=your_client_id_here

# Server/Guild ID where the bot operates - reserved for future use
GUILD_ID=your_guild_id_here
